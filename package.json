{
  "name": "asset-manage",
  "displayName": "Asset Manage",
  "description": "%extension.description%",
  "version": "0.2.1",
  "publisher": "zqt",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Visualization"
  ],
  "keywords": [
    "asset",
    "image",
    "font",
    "preview",
    "media",
    "resource",
    "sidebar",
    "静态资源",
    "图片",
    "媒体",
    "字体",
    "Office",
    "其他",
    "预览",
    "侧边栏",
    "静态资源管理",
    "静态资源预览",
    "静态资源侧边栏"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "assetmanage",
          "title": "%extension.title%",
          "icon": "resources/assetmanage-icon-dark.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "assetManage.refreshIndexes",
        "title": "%extension.refreshCommand%"
      },
      {
        "command": "assetManage.previewFontInSidebar",
        "title": "%extension.previewFontCommand%"
      },
      {
        "command": "assetManage.showImageGallery",
        "title": "%extension.showGalleryCommand%",
        "icon": "$(file-media)"
      },
      {
        "command": "assetManage.openImagesSidebar",
        "title": "%extension.openSidebarCommand%"
      }
    ],
    "keybindings": [
      {
        "command": "assetManage.showImageGallery",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a",
        "when": "true"
      }
    ],
    "views": {
      "assetmanage": [
        {
          "id": "assetManage.imagesView",
          "type": "webview",
          "name": "%extension.viewTitle%"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "assetManage.previewFontInSidebar",
          "group": "navigation@5",
          "when": "resourceExtname =~ /\\.(ttf|otf|woff|woff2)$/i"
        }
      ],
      "view/title": [
        {
          "command": "assetManage.refreshIndexes",
          "when": "view == assetManage.imagesView",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "%extension.configTitle%",
      "properties": {
        "assetManage.scanInclude": {
          "type": "array",
          "default": [
            "**/*"
          ],
          "description": "%extension.scanIncludeDesc%"
        },
        "assetManage.scanExclude": {
          "type": "array",
          "default": [
            "**/node_modules/**",
            "**/.git/**",
            "**/dist/**",
            "**/build/**"
          ],
          "description": "%extension.scanExcludeDesc%"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "watch:no-op": "echo no-op",
    "dev:gui": "cd GUI && npm run dev",
    "build:gui": "cd GUI && npm run build",
    "prebuild": "npm run build:gui",
    "vscode:prepublish": "npm run prebuild && npm run compile"
  },
  "dependencies": {
    "fast-glob": "^3.3.2",
    "fontkit": "^2.0.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.11.19",
    "@types/sinon": "^21.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^2.5.2",
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "sinon": "^21.0.1",
    "typescript": "^5.3.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BitePro/asset-manage"
  },
  "bugs": {
    "url": "https://github.com/BitePro/asset-manage/issues"
  },
  "homepage": "https://github.com/BitePro/asset-manage"
}
